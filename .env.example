# Copy this file to .env and fill the values before running Docker Compose.

# database
DB_HOST=db
DB_PORT=5432
DB_NAME=eadownloader
DB_USER=eadownloader
DB_PASSWORD=change-this-password

# telegram
BOT_API_URL=https://api.telegram.org
BOT_TOKEN=12345678:ABC-DEF1234ghIkl-zyx57W2P0s
CONCURRENT_UPDATES=10

# media and files
DOWNLOADS_DIR=downloads
MAX_DURATION=1h
MAX_FILE_SIZE=1000MB
CACHING=true

# proxy (optional: https, http, socks5)
# PROXY=http://proxy:8080

# default chat settings
DEFAULT_ENABLE_CAPTIONS=true
DEFAULT_ENABLE_SILENT=false
DEFAULT_ENABLE_NSFW=false
DEFAULT_MEDIA_ALBUM_LIMIT=10
DEFAULT_LANGUAGE=tr
DEFAULT_DELETE_LINKS=false
AUTOMATIC_LANGUAGE_DETECTION=true
COBALT_API_URL=http://cobalt-api:9000

# public mode: leave WHITELIST empty/commented.
# WHITELIST=123456789,-1001234567890

# optional admin user ids for /stats and diagnostics
# ADMINS=123456789

# captions
CAPTIONS_HEADER="<a href='{{url}}'>source</a> - @{{username}}"
CAPTIONS_DESCRIPTION="<blockquote expandable>{{text}}</blockquote>"

# observability, bound to 127.0.0.1 by docker-compose.yaml
PROFILER_PORT=6060
METRICS_PORT=8080
LOG_LEVEL=info

# dev only
PGWEB_PORT=8081
PGWEB_USER=admin
PGWEB_PASSWORD=password
